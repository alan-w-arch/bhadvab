        "data": {
          "description": "Converts raw categories into numeric language that models understand — from simple labels to sophisticated statistical embeddings.",
          "dbId": "69abb409b6b43632e87b6d72",
          "characterId": "categorical_encoder",
          "level": 1,
          "levelName": "Number Stamper",
          "power": "Novice",
          "componentName": "Label Encoding",
          "code": "def label_encoding(df):\n    \"\"\"Label Encoding: convert categories to numbers (0, 1, 2, ...)\"\"\"\n    column = df.attrs.get('column')\n    encoder = LabelEncoder()\n    df[column] = encoder.fit_transform(df[column])\n    return df",
          "schemaInputs": [
            {
              "name": "column",
              "type": "string",
              "description": "Column name to encode",
              "required": true
            }
          ]
        },
