        "data": {
          "description": "Scrubs raw text of noise — slashing punctuation, URLs, emojis, HTML, and stopwords into clean linguistic tokens.",
          "dbId": "69abb409b6b43632e87b6d73",
          "characterId": "text_cleaner",
          "level": 1,
          "levelName": "Case Crusher",
          "power": "Novice",
          "componentName": "Lowercase Text",
          "code": "def lowercase_text(df):\n    \"\"\"Convert text to lowercase\"\"\"\n    if isinstance(df, pd.DataFrame):\n        # Apply to all string columns\n        for col in df.select_dtypes(include=['object']).columns:\n            df[col] = df[col].str.lower()\n        return df\n    return df.lower()",
