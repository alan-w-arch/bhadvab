      "3e9693fd-baf1-42ff-bf15-403c5c1623d8": {
        "id": "3e9693fd-baf1-42ff-bf15-403c5c1623d8",
        "type": "Data Cleaning",
        "label": "The Anomaly Warden",
        "x": 364,
        "y": 397,
        "width": 160,
        "height": 148,
        "inputs": [],
        "outputs": [],
        "data": {
          "description": "Detects and neutralises rogue data points — from simple range checks to intelligent density-based detection.",
          "dbId": "69abb409b6b43632e87b6d6f",
          "characterId": "outlier_handler",
          "level": 1,
          "levelName": "Range Guardian",
          "power": "Novice",
          "componentName": "Remove Outliers IQR",
          "code": "def remove_outliers_iqr(df):\n    \"\"\"Remove outliers using IQR method\n    \n    Args:\n        df: DataFrame to process\n        column: Column name to check for outliers. If None, processes all numeric columns.\n    \"\"\"\n    column = df.attrs.get('column')\n    if column is not None:\n        # Single column mode\n        Q1 = df[column].quantile(0.25)\n        Q3 = df[column].quantile(0.75)\n        IQR = Q3 - Q1\n        lower_bound = Q1 - 1.5 * IQR\n        upper_bound = Q3 + 1.5 * IQR\n        return df[(df[column] >= lower_bound) & (df[column] <= upper_bound)]\n    else:\n        # Multi-column mode: remove outliers from all numeric columns\n        result = df.copy()\n        numeric_cols = result.select_dtypes(include=[np.number]).columns\n        \n        for col in numeric_cols:\n            Q1 = result[col].quantile(0.25)\n            Q3 = result[col].quantile(0.75)\n            IQR = Q3 - Q1\n            lower_bound = Q1 - 1.5 * IQR\n            upper_bound = Q3 + 1.5 * IQR\n            result = result[(result[col] >= lower_bound) & (result[col] <= upper_bound)]\n        \n        return result",
          "schemaInputs": [
            {
              "name": "column",
              "type": "string",
              "description": "Column name to check for outliers",
              "required": true
            }
          ]
        },
        "status": "idle"
      },
      "3d501fd9-01a2-4b91-bb30-dea17cbf9f90": {
        "id": "3d501fd9-01a2-4b91-bb30-dea17cbf9f90",
        "type": "Data Preprocessing",
        "label": "The Equalizer",
        "x": 344,
        "y": 129,
        "width": 160,
        "height": 124,
        "inputs": [],
        "outputs": [],
        "data": {
          "description": "Brings all numeric features onto a level playing field so no single variable dominates the model.",
          "dbId": "69abb409b6b43632e87b6d70",
          "characterId": "feature_scaler",
          "level": 1,
          "levelName": "Boundary Binder",
          "power": "Novice",
          "componentName": "Min-Max Scaling",
          "code": "def min_max_scaling(df):\n    \"\"\"Min-Max Scaling: scale to range [0, 1] or custom range\"\"\"\n    feature_range = df.attrs.get('feature_range', (0, 1))\n    from sklearn.preprocessing import MinMaxScaler\n    scaler = MinMaxScaler(feature_range=feature_range)\n    return pd.DataFrame(scaler.fit_transform(df), columns=df.columns)",
          "schemaInputs": [
            {
              "name": "feature_range",
              "type": "tuple",
              "description": "Target range for scaling",
              "required": false,
              "default_value": "(0, 1)"
            }
          ]
        },
        "status": "idle"
      },
